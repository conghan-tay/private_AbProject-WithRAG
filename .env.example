# Local Django settings. Copy to .env for local development.
# Real environment variables always take precedence over values in this file.

DJANGO_DEBUG=True
DJANGO_SECRET_KEY=insecure-local-dev-key
DATABASE_URL=postgres://filevault:filevault@localhost:5432/filevault
REDIS_URL=

RATE_LIMIT_CALLS=2
RATE_LIMIT_PERIOD=1
STORAGE_LIMIT_BYTES=10485760
MAX_UPLOAD_SIZE_BYTES=10485760

# Generate with:
# python -c "from cryptography.hazmat.primitives.ciphers.aead import AESGCM; import base64; print(base64.urlsafe_b64encode(AESGCM.generate_key(bit_length=256)).decode())"
ENCRYPTION_KEY=
ENCRYPTION_CHUNK_SIZE_BYTES=1048576

# Required only for real Ask the Vault embedding integration tests/runtime.
OPENAI_API_KEY=your-openai-api-key
RAG_EMBEDDING_MODEL=text-embedding-3-small
RAG_EMBEDDING_DIMENSIONS=1536
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=150
RAG_LLM_MODEL=gpt-4.1-mini

# Local Docker E2E only. Refused when DJANGO_DEBUG=False.
ASKVAULT_RAG_E2E_FAKE=False
